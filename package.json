{
  "name": "@opencudem/slack-cli",
  "version": "0.3.2",
  "description": "Cookie-first Slack CLI for channels, DMs, messages, and threads",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "slack-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "login": "tsx src/cli.ts session:import"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencudem/slack-cli.git"
  },
  "bugs": {
    "url": "https://github.com/opencudem/slack-cli/issues"
  },
  "homepage": "https://github.com/opencudem/slack-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "slack",
    "cli",
    "messages",
    "threads",
    "terminal"
  ],
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.3",
    "tough-cookie": "^6.0.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
